{
  "name": "plan-visualizer",
  "version": "1.5.34",
  "description": "Self-contained project dashboard for Claude Code projects",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "generate": "node tools/generate-plan.js",
    "generate:watch": "node tools/generate-plan.js --watch",
    "dashboard": "node tools/generate-dashboard.js",
    "dashboard:watch": "node tools/generate-dashboard.js --watch",
    "init:status": "node tools/init-sdlc-status.js",
    "build": "npm run generate && npm run init:status && npm run dashboard",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cleanup:branches": "bash scripts/cleanup-branches.sh",
    "cleanup:branches:dry": "bash scripts/cleanup-branches.sh --dry-run",
    "prepare": "husky",
    "migrate-config": "node tools/migrate-config.js",
    "migrate-config:dry": "node tools/migrate-config.js --dry-run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml,html,css}": "prettier --write",
    "*.js": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.2.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  }
}
