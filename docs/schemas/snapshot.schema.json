{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/snapshot.schema.json",
  "title": "Plan Visualizer Snapshot",
  "description": "JSON snapshot schema for historical tracking of project metrics",
  "type": "object",
  "required": ["generatedAt", "data"],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this snapshot was generated"
    },
    "commit": {
      "type": ["string", "null"],
      "description": "Git commit SHA at the time of generation"
    },
    "data": {
      "type": "object",
      "description": "All parsed dashboard data at the time of generation",
      "properties": {
        "epics": {
          "type": "array",
          "description": "List of epics",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "stories": {
          "type": "array",
          "description": "List of user stories",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "epicId": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "priority": { "type": "string" },
              "estimate": { "type": ["string", "null"] },
              "branch": { "type": ["string", "null"] },
              "atRisk": { "type": ["boolean", "null"] }
            }
          }
        },
        "bugs": {
          "type": "array",
          "description": "List of bugs",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "severity": { "type": "string" },
              "status": { "type": "string" },
              "relatedStory": { "type": ["string", "null"] }
            }
          }
        },
        "costs": {
          "type": "object",
          "description": "Cost data keyed by story ID",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "projectedUsd": { "type": "number" },
              "costUsd": { "type": "number" },
              "inputTokens": { "type": "number" },
              "outputTokens": { "type": "number" }
            }
          }
        },
        "coverage": {
          "type": "object",
          "description": "Test coverage metrics",
          "properties": {
            "available": { "type": "boolean" },
            "overall": { "type": "number" },
            "lines": { "type": "number" },
            "statements": { "type": "number" },
            "functions": { "type": "number" },
            "branches": { "type": "number" },
            "meetsTarget": { "type": "boolean" }
          }
        },
        "lessons": {
          "type": "array",
          "description": "List of lessons learned",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "testCases": {
          "type": "array",
          "description": "List of test cases",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "relatedStory": { "type": ["string", "null"] },
              "status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
